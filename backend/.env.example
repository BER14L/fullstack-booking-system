# ----------------------------------------------------------------------------
# SmartReserve backend environment variables
# Copy this file to `.env` and fill in real values.
# ----------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=4000

# Database (Postgres). Supabase connection strings work here too.
DATABASE_URL=postgresql://smartreserve:smartreserve@localhost:5432/smartreserve?schema=public

# JWT. Generate a long random string for production:  openssl rand -hex 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h

# CORS: comma-separated list of allowed origins for the browser frontend.
CORS_ORIGIN=http://localhost:3000

# Stripe (test keys during development)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

# Pricing (amount per booking, in the smallest currency unit — e.g. cents)
BOOKING_PRICE_CENTS=5000
BOOKING_CURRENCY=usd

# SMTP (Mailtrap / SendGrid / Resend / etc.)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SmartReserve <no-reply@smartreserve.local>
